{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(*)",
      "Agent(*)",
      "Skill(*)",
      "WebSearch(*)",
      "WebFetch(*)",
      "NotebookEdit(*)",
      "TaskCreate(*)",
      "TaskUpdate(*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(sudo rm *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | bash*)",
      "Bash(wget * | bash*)"
    ]
  }
}
